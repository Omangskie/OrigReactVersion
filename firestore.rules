rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isBootstrapAdminEmail() {
      return signedIn()
        && (
          request.auth.token.email == 'kylebriantonido123@gmail.com'
          || request.auth.token.firebase.identities['email'][0] == 'kylebriantonido123@gmail.com'
        );
    }

    function isAdmin() {
      return (
        isBootstrapAdminEmail()
        || (
          signedIn()
          && exists(userDocPath(request.auth.uid))
          && get(userDocPath(request.auth.uid)).data.role == 'admin'
          && get(userDocPath(request.auth.uid)).data.status != 'deleted'
          && get(userDocPath(request.auth.uid)).data.status != 'suspended'
        )
      );
    }

    function validRoleForSelfCreate() {
      return request.resource.data.role == 'customer'
        || (isBootstrapAdminEmail() && request.resource.data.role == 'admin');
    }

    function validStatusForCreate() {
      return request.resource.data.status == 'active';
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && validRoleForSelfCreate()
        && validStatusForCreate();

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    function isOrderCancellation() {
      return signedIn()
        && resource.data.purchaserUid == request.auth.uid
        && (resource.data.status == 'Pending Payment Approval' || resource.data.status == 'Processing')
        && request.resource.data.status == 'Cancelled'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status']);
    }

    match /orders/{orderDocId} {
      // Customer submits receipt proof and creates own order.
      allow create: if signedIn()
        && request.resource.data.purchaserUid == request.auth.uid
        && request.resource.data.status == 'Pending Payment Approval'
        && request.resource.data.payment.status == 'pending_review'
        && request.resource.data.payment.provider == 'paymongo'
        && request.resource.data.payment.method == 'qrph';

      allow read: if isAdmin() || (signedIn() && resource.data.purchaserUid == request.auth.uid);

      // Admin confirms/rejects receipt proof and moves tracking status.
      allow update: if isAdmin() || isOrderCancellation();
      allow delete: if isAdmin();
    }

    match /showcase/{showcaseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
